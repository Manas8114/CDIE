    FPS["FraudPolicyStrictness"]
    CDR["CallDataRecordVolume"]
    SIM["SIMBoxFraudAttempts"]
    DET["SIMFraudDetectionRate"]
    REV["RevenueLeakageVolume"]
    RET["SubscriberRetentionScore"]
    ARPU["ARPUImpact"]
