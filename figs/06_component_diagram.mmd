%% CDIE v5 — Component Diagram
%% Module-level view with Python packages
graph TB
    subgraph Pipeline_Pkg["cdie/pipeline/ (Offline)"]
        A1["data_generator.py<br/>SCM Simulation<br/>2000 rows, 12 nodes"]
        A2["catl.py<br/>Causal Assumption<br/>Transparency Layer"]
        A3["gfci_discovery.py<br/>GFCI Structure Learning<br/>+ PC Fallback"]
        A4["pcmci_temporal.py<br/>PCMCI+ / Granger<br/>Temporal Discovery"]
        A5["refutation.py<br/>DoWhy 3-Test Suite<br/>Placebo / Random / Subset"]
