        D1["Dashboard.tsx<br/>Main Dashboard + Prescriptive Mode"]
        D2["CausalGraph.tsx<br/>React Flow DAG Visualization"]
    end

    subgraph Data_Artifacts["data/ (Artifacts)"]
        E1["safety_map.db<br/>SQLite Cache"]
        E2["safety_map.json<br/>JSON Export"]
        E3["scm_data.csv<br/>Synthetic Dataset"]
        E4["ground_truth.pkl<br/>True DAG"]
        E5["telecom_playbooks.json<br/>RAG Knowledge Base"]
    end

