# ═══════════════════════════════════════════════════════════════════
# CDIE v5 Environment Variables
# Copy to .env and fill in your values.
# Variables marked [REQUIRED] will cause startup warnings if missing.
# Variables marked [OPTIONAL] have safe defaults.
# ═══════════════════════════════════════════════════════════════════

# ── HuggingFace ────────────────────────────────────────────────────
# [REQUIRED for TGI/OPEA] HuggingFace Hub token for model access
HF_TOKEN=your_hf_token_here

# ── OpenAI (optional fallback LLM) ────────────────────────────────
# [OPTIONAL] Falls back to template-based explanations if not set
OPENAI_API_KEY=

# ── OPEA GenAIComps Endpoints ──────────────────────────────────────
# [OPTIONAL] OPEA LLM TextGen microservice (OpenAI-compatible /v1/)
# In Docker: http://opea-llm-textgen:9000  |  Local: http://localhost:9000
OPEA_LLM_ENDPOINT=http://localhost:9000

# [OPTIONAL] Direct TGI backend endpoint (fast /generate path)
# In Docker: http://tgi-service:80  |  Local: http://localhost:8008
TGI_ENDPOINT=

# [OPTIONAL] OPEA TEI Embedding (BAAI/bge-base-en-v1.5)
OPEA_EMBEDDING_ENDPOINT=http://localhost:6006

# [OPTIONAL] OPEA TEI Reranking (BAAI/bge-reranker-base)
OPEA_RERANKING_ENDPOINT=http://localhost:8808

# ── LLM Model ─────────────────────────────────────────────────────
# [OPTIONAL] Model ID served by TGI/OPEA
LLM_MODEL_ID=Intel/neural-chat-7b-v3-3

# ── Frontend ───────────────────────────────────────────────────────
# [REQUIRED for Next.js] API base URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Redis Cache ────────────────────────────────────────────────────
# [OPTIONAL] Redis URL for RAG response caching (24h TTL)
# Omit or leave empty to disable caching entirely
REDIS_URL=redis://localhost:6379/0

# ── Storage Paths ─────────────────────────────────────────────────
# [OPTIONAL] Runtime directory for SQLite mirrors and drift snapshots
# IMPORTANT: Use a local path — avoid OneDrive, Dropbox, network shares
# Windows default: %LOCALAPPDATA%\CDIE  |  Linux default: ~/.local/share/cdie
CDIE_RUNTIME_DIR=

# [OPTIONAL] Override for the canonical data directory (safety_map.json, etc.)
# Default: <project_root>/data
CDIE_DATA_DIR=

# ── API Behaviour ─────────────────────────────────────────────────
# [OPTIONAL] Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# [OPTIONAL] SlowAPI rate limit string
RATE_LIMIT=100/minute

# ── Observability ─────────────────────────────────────────────────
# [OPTIONAL] Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# [OPTIONAL] Set to "1" to expose /metrics endpoint with request counters
CDIE_ENABLE_METRICS=1

# ── Intel CPU Optimization ────────────────────────────────────────
# [OPTIONAL] Enable AVX-512/AMX acceleration (Intel Xeon / Sapphire Rapids)
DNNL_MAX_CPU_ISA=AVX512_CORE_AMX
KMP_AFFINITY=granularity=fine,compact,1,0
KMP_BLOCKTIME=1
OMP_NUM_THREADS=4
