# CDIE v4 Environment Variables Template
# Copy to .env and fill in your values

# HuggingFace Token (for TGI model access)
HF_TOKEN=your_hf_token_here

# OpenAI API Key (optional fallback)
OPENAI_API_KEY=

# OPEA LLM Endpoint (auto-configured in Docker)
OPEA_LLM_ENDPOINT=http://localhost:9000

# OPEA TEI Embedding Endpoint
OPEA_EMBEDDING_ENDPOINT=http://localhost:6006

# OPEA TEI Reranking Endpoint
OPEA_RERANKING_ENDPOINT=http://localhost:8808

# Intel Model ID
LLM_MODEL_ID=Intel/neural-chat-7b-v3-3

# Frontend API base (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Runtime storage directory for drift history + SQLite mirrors
# Recommended: use a local writable path outside OneDrive/network sync folders.
CDIE_RUNTIME_DIR=

# Optional explicit data directory override
CDIE_DATA_DIR=

# Intel CPU Optimization (AVX2/AVX-512/AMX)
DNNL_MAX_CPU_ISA=AVX512_CORE_AMX
KMP_AFFINITY=granularity=fine,compact,1,0
KMP_BLOCKTIME=1
OMP_NUM_THREADS=4
